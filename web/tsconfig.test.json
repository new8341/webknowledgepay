{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "noEmitOnError": true,
    "outDir": "./.tmp-test"
  },
  "include": ["tests/**/*.ts", "src/api/**/*.ts", "src/store/modules/cart.ts", "src/store/modules/learning.ts", "src/types/index.ts"]
}

